<h2>Edit Task</h2>

<form action="/tasks/<%= @task.id %>/update" method="post">
  <label for="title">Title:</label>
  <input type="text" id="title" name="title" value="<%= @task.title %>" required>
  <br><br>
  <input type="submit" value="Update Task">
</form>

<a href="/">← Back to Tasks</a>


